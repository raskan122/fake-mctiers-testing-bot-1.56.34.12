import json
import os
import sys

_SETTINGS_FILE = os.path.join("data", "settings.json")
os.makedirs("data", exist_ok=True)


def _load_settings() -> dict:
    try:
        with open(_SETTINGS_FILE, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_settings(data: dict):
    with open(_SETTINGS_FILE, "w") as f:
        json.dump(data, f, indent=2)


def reload():
    """Reload all config values from settings.json into this module."""
    s = _load_settings()
    current_module = sys.modules[__name__]
    for key, value in s.items():
        setattr(current_module, key, value)
    _rebuild_derived()


def _rebuild_derived():
    """Rebuild derived dicts that depend on individual IDs."""
    current_module = sys.modules[__name__]
    current_module.REGION_DATA = {
        "na": {"waitlist_role_id": NA_WAITLIST_ROLE_ID, "channel_id": NA_WAITLIST_CHANNEL_ID, "category_id": NA_TESTING_CATEGORY_ID, "region_role_id": NA_REGION_ROLE_ID},
