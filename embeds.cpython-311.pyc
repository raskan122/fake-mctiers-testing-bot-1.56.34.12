import os
import asyncio
import logging
import discord
from discord.ext import commands
from dotenv import load_dotenv

import config
from utils.db_init import init_db
from utils.ui import WaitlistView, QueueView

load_dotenv()
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s:%(levelname)s:%(name)s: %(message)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)

# Initialize SQLite database tables on startup
init_db()

BOT_TOKEN = os.getenv("DISCORD_BOT_TOKEN")
if not BOT_TOKEN:
    logging.critical("CRITICAL ERROR: DISCORD_BOT_TOKEN not set. Add it as a secret named DISCORD_BOT_TOKEN.")


class TestingBot(commands.Bot):
    def __init__(self):
        intents = discord.Intents.default()
        intents.members = True
        intents.message_content = True
        super().__init__(
            command_prefix=commands.when_mentioned_or("!#$UNUSED"),
            intents=intents
        )

    async def setup_hook(self):
        self.add_view(WaitlistView())
        for region_key in config.REGION_DATA:
            if 'maps_to' not in config.REGION_DATA[region_key]:
                self.add_view(QueueView(region=region_key, queue_open=True))

        logging.info("Initialized all persistent views.")

        cogs_dir = 'cogs'
        for filename in sorted(os.listdir(f'./{cogs_dir}')):
            if filename.endswith('.py'):
                try:
                    await self.load_extension(f'cogs.{filename[:-3]}')
                    logging.info(f"Loaded cog: {filename}")
                except Exception as e:
                    logging.error(f"Failed to load cog {filename}: {e}", exc_info=True)

        # The original commands.py decorates commands with @app_commands.guilds(config.GUILD_ID).
        # At import time GUILD_ID may be 1 (placeholder), so those commands land in the
        # placeholder guild slot.  Move them all to global scope so they always sync.
        # The @app_commands.guilds(GUILD_ID) decorator sets cmd._guild_ids on each command.
        # At startup GUILD_ID is 1 (placeholder), so we must:
        #   1. Remove the command from the placeholder-guild slot
        #   2. Clear _guild_ids so the tree doesn't re-route it back to a guild
        #   3. Re-add globally with override so it lands in _global_commands
        placeholder = discord.Object(id=1)
        promoted = 0
        for cmd in list(self.tree.get_commands(guild=placeholder)):
            self.tree.remove_command(cmd.name, guild=placeholder)
            cmd._guild_ids = None   # clear the guild restriction baked in by the decorator
            self.tree.add_command(cmd, override=True)
            promoted += 1
        if promoted:
            logging.info(f"Promoted {promoted} guild-locked commands to global scope.")

        # Sync commands globally AND to the configured guild for instant availability
        try:
            if config.GUILD_ID and config.GUILD_ID != 1:
                guild = discord.Object(id=config.GUILD_ID)
                # Copy global commands into the guild for instant (no-delay) availability
                self.tree.copy_global_to(guild=guild)
                synced = await self.tree.sync(guild=guild)
                logging.info(f"Synced {len(synced)} commands to guild {config.GUILD_ID}.")
            else:
                # Guild not configured yet — sync globally (propagates in ~1 hour)
                synced = await self.tree.sync()
                logging.info(f"Synced {len(synced)} commands globally (GUILD_ID not configured).")
        except Exception as e:
            logging.error(f"Failed to sync command tree: {e}")

    async def on_ready(self):
        logging.info(f"Logged in as {self.user} (ID: {self.user.id})")
        logging.info("Bot is ready. Use /setup in your server to configure channels and roles.")
        await self._cleanup_stale_queue_messages()

    async def _cleanup_stale_queue_messages(self):
        """Delete old per-region queue messages that were left behind before the shared-message fix."""
        import json
        DATA_DIR = os.path.join(os.path.dirname(__file__), "data")
        stale_files = ["queue_message_eu.json", "queue_message_na.json", "queue_message_as.json"]

        # Gather every fallback channel we should search in
        fallback_channel_id = config.QUEUE_JOIN_CHANNEL_ID
        guild = self.get_guild(config.GUILD_ID)
        fallback_channel = guild.get_channel(fallback_channel_id) if guild else None

        deleted = 0
        for fname in stale_files:
            fpath = os.path.join(DATA_DIR, fname)
            if not os.path.exists(fpath):
                continue
            try:
                with open(fpath) as f:
                    data = json.load(f)
                msg_id = data.get("id")
                if msg_id and fallback_channel:
                    try:
                        msg = await fallback_channel.fetch_message(msg_id)
                        await msg.delete()
                        deleted += 1
                    except (discord.NotFound, discord.Forbidden, discord.HTTPException):
                        pass
                os.remove(fpath)
            except Exception as e:
                logging.warning(f"Could not clean up {fname}: {e}")

        if deleted:
            logging.info(f"Cleaned up {deleted} stale queue message(s) from the channel.")


bot = TestingBot()

if BOT_TOKEN:
    bot.run(BOT_TOKEN, log_handler=None)
else:
    logging.error("Bot not started: DISCORD_BOT_TOKEN is missing.")
