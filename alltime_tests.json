        updates = {}
        if eu:       updates["EU_TESTING_CATEGORY_ID"] = eu.id
        if na:       updates["NA_TESTING_CATEGORY_ID"] = na.id
        if as_au:    updates["AS_AU_TESTING_CATEGORY_ID"] = as_au.id
        if high:     updates["HIGH_TESTING_CATEGORY_ID"] = high.id
        if overflow: updates["TESTING_OVERFLOW_CATEGORY_ID"] = overflow.id

        if not updates:
