"""
/setup command — configure all bot channels, categories, and roles without editing files.
All settings are persisted to data/settings.json and applied immediately.
"""
import discord
from discord import app_commands
from discord.ext import commands
import logging
import sys

import config


def _save_and_reload(updates: dict):
    """Merge updates into settings.json and hot-reload config module values."""
    s = config._load_settings()
    s.update(updates)
    config.save_settings(s)
    # Apply directly to the live config module
    mod = sys.modules["config"]
    for k, v in updates.items():
        setattr(mod, k, v)
    config._rebuild_derived()


def _cfg_id(value, fallback=1) -> int:
    return value if value and value != 1 else fallback


class SetupCog(commands.Cog, name="Setup"):
    """Bot configuration commands (owner/admin only)."""

    def __init__(self, bot: commands.Bot):
        self.bot = bot

    # ── Permission guard ──────────────────────────────────────────────────────
    async def _is_admin(self, interaction: discord.Interaction) -> bool:
        if not interaction.guild:
            await interaction.response.send_message("Run this command inside your server.", ephemeral=True)
            return False
        if interaction.user.guild_permissions.administrator:
            return True
        # Also allow anyone with OWNER or MANAGER role configured
        owner_role = interaction.guild.get_role(config.OWNER_ROLE_ID)
        manager_role = interaction.guild.get_role(config.MANAGER_ROLE_ID)
        for role in interaction.user.roles:
            if role in (owner_role, manager_role):
                return True
        await interaction.response.send_message(
            "You need **Administrator** permission or the configured Owner/Manager role to use /setup.",
            ephemeral=True
        )
        return False

    # ── Command group ─────────────────────────────────────────────────────────
    setup_group = app_commands.Group(
        name="setup",
        description="Configure the bot (admin only)."
    )

    # ── /setup guild ──────────────────────────────────────────────────────────
    @setup_group.command(name="guild", description="Set the server (guild) ID the bot operates in.")
    async def setup_guild(self, interaction: discord.Interaction):
        if not await self._is_admin(interaction):
            return
        guild_id = interaction.guild_id
        _save_and_reload({"GUILD_ID": guild_id})
        embed = discord.Embed(
            title="Guild Configured",
            description=f"Guild ID set to **{guild_id}**.\nRestart the bot for command sync to take effect.",
            color=discord.Color.green()
        )
        await interaction.response.send_message(embed=embed, ephemeral=True)

    # ── /setup channels ───────────────────────────────────────────────────────
    @setup_group.command(
        name="channels",
        description="Set the main bot channels (logging, results, leaderboard, transcripts, etc.)."
    )
    @app_commands.describe(
        logging="Channel for bot action logs",
        results="Channel where test results are posted",
        leaderboard="Channel for the leaderboard",
        transcripts="Channel where ticket transcripts are saved",
        queue_join="Channel where players join the queue",
        request_test="Channel where players request tests (waitlist panel)",
        end_of_month="Channel for end-of-month test summaries",
        failed_quota="Channel for testers who failed quota",
    )
    async def setup_channels(
        self,
        interaction: discord.Interaction,
        logging: discord.TextChannel = None,
        results: discord.TextChannel = None,
        leaderboard: discord.TextChannel = None,
        transcripts: discord.TextChannel = None,
        queue_join: discord.TextChannel = None,
        request_test: discord.TextChannel = None,
        end_of_month: discord.TextChannel = None,
        failed_quota: discord.TextChannel = None,
    ):
        if not await self._is_admin(interaction):
            return

        updates = {}
        if logging:       updates["LOGGING_CHANNEL_ID"] = logging.id
        if results:       updates["RESULTS_CHANNEL_ID"] = results.id
        if leaderboard:   updates["LEADERBOARD_CHANNEL_ID"] = leaderboard.id
        if transcripts:   updates["TRANSCRIPTS_CHANNEL_ID"] = transcripts.id
        if queue_join:    updates["QUEUE_JOIN_CHANNEL_ID"] = queue_join.id
        if request_test:  updates["REQUEST_TEST_CHANNEL_ID"] = request_test.id
        if end_of_month:  updates["TESTS_END_OF_THE_MONTH_CHANNEL_ID"] = end_of_month.id
        if failed_quota:  updates["FAILED_QUOTA_TESTERS_CHANNEL_ID"] = failed_quota.id

        if not updates:
            return await interaction.response.send_message("No channels provided.", ephemeral=True)

        _save_and_reload(updates)

        lines = [f"**{k}** → <#{v}>" for k, v in updates.items()]
        embed = discord.Embed(
            title="Channels Updated",
            description="\n".join(lines),
            color=discord.Color.green()
        )
        await interaction.response.send_message(embed=embed, ephemeral=True)

    # ── /setup waitlist-channels ──────────────────────────────────────────────
    @setup_group.command(
        name="waitlist-channels",
        description="Set the per-region waitlist channels."
    )
    @app_commands.describe(
        eu_waitlist="EU waitlist channel",
        na_waitlist="NA waitlist channel",
        as_au_waitlist="AS/AU waitlist channel",
    )
    async def setup_waitlist_channels(
        self,
        interaction: discord.Interaction,
        eu_waitlist: discord.TextChannel = None,
        na_waitlist: discord.TextChannel = None,
        as_au_waitlist: discord.TextChannel = None,
    ):
        if not await self._is_admin(interaction):
            return

        updates = {}
        if eu_waitlist:   updates["EU_WAITLIST_CHANNEL_ID"] = eu_waitlist.id
        if na_waitlist:   updates["NA_WAITLIST_CHANNEL_ID"] = na_waitlist.id
        if as_au_waitlist: updates["AS_AU_WAITLIST_CHANNEL_ID"] = as_au_waitlist.id

        if not updates:
            return await interaction.response.send_message("No channels provided.", ephemeral=True)

        _save_and_reload(updates)
        lines = [f"**{k}** → <#{v}>" for k, v in updates.items()]
        embed = discord.Embed(title="Waitlist Channels Updated", description="\n".join(lines), color=discord.Color.green())
        await interaction.response.send_message(embed=embed, ephemeral=True)

    # ── /setup categories ─────────────────────────────────────────────────────
